# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /auxot-agent ./cmd/auxot-agent

# ── Stage 2: Runtime ──────────────────────────────────────────────────────────
FROM alpine:3.21
RUN apk add --no-cache bash git ca-certificates

COPY --from=build /auxot-agent /usr/local/bin/auxot-agent

# Agent directory is bind-mounted from the host.
# It must contain SOUL.md and agent.yaml.
WORKDIR /agent

# Configuration via environment variables:
#   AUXOT_AGENT_KEY     — agent key (required)
#   AUXOT_SERVER_URL    — Auxot server URL (required), e.g. http://auxot:8080
#   AUXOT_AGENT_DIR     — agent directory (default: /agent)
ENTRYPOINT ["auxot-agent"]
