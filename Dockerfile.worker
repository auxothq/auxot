# Auxot Worker — GPU + CLI inference worker with Claude Code CLI
#
# Handles two worker modes based on router policy:
#   gpu  — downloads model from HuggingFace, spawns llama.cpp, serves inference
#   cli  — spawns Claude Code (claude CLI) as the inference backend
#
# Base: node:24-bookworm-slim (not pure distroless) because the Claude Code
# binary installed via npm is a Node.js shell-script wrapper that requires
# /bin/sh to exec. A shell-free distroless image breaks subprocess spawning.
# Runs as uid 65532 (nonroot) — same UID as gcr.io/distroless nonroot.
#
# Required environment variables:
#   AUXOT_GPU_KEY        Worker authentication key (gpu_... from Auxot dashboard)
#   AUXOT_ROUTER_URL     Router WebSocket URL (e.g. wss://auxot.example.com/ws)
#
# Optional environment variables:
#   ANTHROPIC_API_KEY    Required by Claude Code for cloud inference (cli mode)
#   CLAUDE_PATH          Override path to claude binary (default: claude)
#   AUXOT_MODELS_DIR     Model cache directory (default: /home/nonroot/.auxot/models)
#   AUXOT_LLAMA_URL      External llama-server URL — skips model download (dev)
#   AUXOT_LLAMA_BINARY   Path to local llama-server binary — skips download
#   AUXOT_MODEL_FILE     Path to local GGUF model file — skips download
#   AUXOT_LOG_LEVEL      Log level: debug, info, warn, error (default: info)
#
# Supports multi-arch builds via docker buildx:
#   docker buildx build -f Dockerfile.worker --platform linux/amd64,linux/arm64 .

# ============================================================================
# Stage 1: go-builder — cross-compile the auxot-worker binary
# ============================================================================
FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS go-builder

ARG TARGETOS TARGETARCH

RUN apk add --no-cache git

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} go build \
    -ldflags="-s -w" \
    -o /build/auxot-worker \
    ./cmd/auxot-worker

# ============================================================================
# Stage 2: final — slim runtime, non-root, claude + auxot-worker
# ============================================================================
FROM node:24-bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally in the final stage so npm creates proper bin
# symlinks. Copying a global install across stages copies the raw file that
# the symlink resolved to, stripping the symlink — Node.js then cannot find
# the package's own dependencies from the resolved path.
RUN npm install -g @anthropic-ai/claude-code

RUN groupadd --gid 65532 nonroot && \
    useradd --uid 65532 --gid 65532 --create-home --shell /usr/sbin/nologin nonroot

COPY --from=go-builder /build/auxot-worker /usr/local/bin/auxot-worker

# Model and binary cache land in the nonroot home; mount a volume here for
# GPU workers to persist downloaded models across container restarts.
VOLUME ["/home/nonroot/.auxot"]

USER nonroot

ENTRYPOINT ["/usr/local/bin/auxot-worker"]
